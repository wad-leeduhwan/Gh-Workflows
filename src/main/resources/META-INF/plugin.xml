<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.wadleeduhwan.ghworkflows</id>
    <name>Gh-Workflows</name>
    <vendor>wad-leeduhwan</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>
    <depends>org.jetbrains.plugins.github</depends>

    <resource-bundle>messages.WorkflowBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="GitHub Workflows"
                    anchor="right"
                    factoryClass="com.github.wadleeduhwan.ghworkflows.toolWindow.WorkflowToolWindowFactory"
                    icon="com.github.wadleeduhwan.ghworkflows.icons.WorkflowIcons.ToolWindow"/>

        <projectService
                serviceImplementation="com.github.wadleeduhwan.ghworkflows.services.GitHubWorkflowService"/>

        <notificationGroup id="GhWorkflows.Notification"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>
</idea-plugin>
